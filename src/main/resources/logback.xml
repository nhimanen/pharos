<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <statusListener class="ch.qos.logback.core.status.NopStatusListener"/>
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
    </appender>

    <!-- Verbose logging when -Dcodesearch.verbose=true -->
    <appender name="STDERR_VERBOSE" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="MCP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${user.home}/.pharos/logs/mcp.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${user.home}/.pharos/logs/mcp.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDERR"/>
    </root>

    <logger name="com.pharos.mcp.McpServer" level="INFO" additivity="false">
        <appender-ref ref="MCP_FILE"/>
    </logger>

    <logger name="com.pharos.mcp.McpToolRegistry" level="DEBUG" additivity="false">
        <appender-ref ref="MCP_FILE"/>
    </logger>

    <!-- Silence noisy JavaParser symbol resolver warnings at INFO level -->
    <logger name="com.github.javaparser" level="ERROR"/>
    <logger name="org.jgrapht" level="WARN"/>
    <logger name="ai.djl" level="WARN"/>
</configuration>
