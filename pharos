# ── Argument parser ───────────────────────────────────────────────────────────

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="pharos",
        description="Java code search and navigation",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="Run 'pharos <command> --help' for detailed usage of each command.",
        add_help=True,
    )
    sub = parser.add_subparsers(dest="command", metavar="command")

    # web
    p_web = sub.add_parser(
        "web",
        help="Open the web UI in a browser (starts daemon if needed)",
