#!/usr/bin/env python3
"""
pharos - Python CLI client for the Pharos code search tool.

Uses a persistent background daemon (pharos web server) to avoid JVM cold-start
on every command. The daemon is started automatically on first use and reused
for subsequent calls.

Install:
  cp pharos ~/.local/bin/pharos && chmod +x ~/.local/bin/pharos

JAR resolution order:
  1. <script-dir>/target/pharos-*.jar   (development / repo checkout)
  2. ~/.pharos/bin/pharos.jar            (installed)

Daemon port: 7171  (override with PHAROS_PORT env var)
"""

import argparse
import glob
import json
import os
import signal
import subprocess
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path

# ── JAR resolution ────────────────────────────────────────────────────────────

def _resolve_jar() -> Path:
    """Find the pharos JAR: prefer local target/ build, fall back to installed."""
    script_dir = Path(__file__).resolve().parent
    candidates = sorted(glob.glob(str(script_dir / "target" / "pharos-*.jar")), reverse=True)
    if candidates:
        return Path(candidates[0])
    return Path.home() / ".pharos" / "bin" / "pharos.jar"

JAR = _resolve_jar()
PHAROS_DIR = Path.home() / ".pharos"
DAEMON_PORT = int(os.environ.get("PHAROS_PORT", "7171"))
DAEMON_PID_FILE = PHAROS_DIR / "daemon.pid"
DAEMON_LOG_FILE = PHAROS_DIR / "daemon.log"
BASE_URL = f"http://localhost:{DAEMON_PORT}"

# ── Daemon management ─────────────────────────────────────────────────────────

def _is_daemon_running() -> bool:
    """Return True if the daemon is responding on its health endpoint."""
    try:
        with urllib.request.urlopen(f"{BASE_URL}/health", timeout=1) as resp:
            return resp.status == 200
    except Exception:
        return False


def _start_daemon():
    """Start the pharos web server as a background daemon."""
    if not JAR.exists():
        die(f"pharos JAR not found at {JAR}\n"
            f"Run: mvn clean package -DskipTests")

    PHAROS_DIR.mkdir(parents=True, exist_ok=True)
    log_fh = open(DAEMON_LOG_FILE, "a")
    proc = subprocess.Popen(
        ["java", "--enable-native-access=ALL-UNNAMED",
         "--add-opens", "java.base/java.nio.channels.spi=ALL-UNNAMED",
         "-jar", str(JAR),
         "web", "--port", str(DAEMON_PORT), "--no-open"],
        stdout=log_fh,
        stderr=log_fh,
        stdin=subprocess.DEVNULL,
        start_new_session=True,
    )
    DAEMON_PID_FILE.write_text(str(proc.pid))

    # Wait up to 30s for the server to become ready
    deadline = time.monotonic() + 30
    while time.monotonic() < deadline:
        if _is_daemon_running():
            return
        time.sleep(0.3)

    die(f"pharos daemon failed to start within 30s.\n"
        f"Check logs: {DAEMON_LOG_FILE}")


def ensure_daemon():
    """Ensure the daemon is running, starting it if necessary."""
    if _is_daemon_running():
        return
    print("Starting pharos daemon...", file=sys.stderr, flush=True)
    _start_daemon()


def _api_get(path: str, params: dict = None) -> object:
    """Make a GET request to the daemon API. Returns parsed JSON."""
    url = f"{BASE_URL}{path}"
    if params:
        filtered = {k: v for k, v in params.items() if v is not None}
        if filtered:
            url += "?" + urllib.parse.urlencode(filtered)
    try:
        with urllib.request.urlopen(url, timeout=60) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        body = e.read().decode(errors="replace")
        die(f"API error {e.code}: {body}")
    except urllib.error.URLError as e:
        die(f"Cannot reach pharos daemon: {e.reason}\n"
            f"Try restarting with: pharos daemon restart")


def die(msg: str):
    print(f"pharos: {msg}", file=sys.stderr)
    sys.exit(1)


# ── Output formatters ─────────────────────────────────────────────────────────

def fmt_search(results: list) -> str:
    if not results:
        return "No results found."
    lines = []
    for r in results:
        doc_type = r.get("docType", "method")
        label = r.get("label", r.get("id", "?"))
        project = r.get("project", "")
        sig = r.get("signature", "")
        javadoc = r.get("javadoc", "")
        fp = r.get("filePath", "")
        start = r.get("startLine", "")
        end = r.get("endLine", "")
        score = r.get("score", 0)

        lines.append(f"[{doc_type}] **{label}** [{project}]  score={score:.3f}")
        if sig:
            lines.append(f"  {sig}")
        if javadoc:
            first_line = javadoc.strip().split("\n")[0][:120]
            lines.append(f"  {first_line}")
        if fp:
            loc = f"{fp}:{start}-{end}" if start else fp
            lines.append(f"  {loc}")
        lines.append("")
    return "\n".join(lines).rstrip()


def fmt_method(r: dict) -> str:
    if not r:
        return "Method not found."
    label = r.get("label", r.get("id", "?"))
    project = r.get("project", "")
    body = r.get("body", "")
    fp = r.get("filePath", "")
    start = r.get("startLine", "")
    end = r.get("endLine", "")
    javadoc = r.get("javadoc", "")

    lines = [f"**{label}** [{project}]"]
    if javadoc:
        lines.append(f"\n{javadoc.strip()}")
    lines.append(f"\n```java\n{body}\n```")
    if fp:
        lines.append(f"\n`{fp}:{start}-{end}`")
    return "\n".join(lines)


def fmt_class(r: dict) -> str:
    if not r:
        return "Class not found."
    label = r.get("label", r.get("qualifiedClassName", "?"))
    project = r.get("project", "")
    body = r.get("body", "")
    fp = r.get("filePath", "")
    start = r.get("startLine", "")
    end = r.get("endLine", "")
    source_available = r.get("sourceAvailable", True)

    lines = [f"**{label}** [{project}]"]
    if not source_available:
        lines.append("\n*(source file unavailable — showing indexed synthesis)*")
    lines.append(f"\n```java\n{body}\n```")
    if fp:
        lines.append(f"\n`{fp}:{start}-{end}`")
    return "\n".join(lines)


def _truncate(items: list, limit: int) -> tuple:
    """Return (visible_items, truncated_count). limit=0 means no cap."""
    if limit > 0 and len(items) > limit:
        return items[:limit], len(items) - limit
    return items, 0


def fmt_refs(results: list, label: str, limit: int = 0) -> str:
    if not results:
        return f"No {label} found."
    visible, hidden = _truncate(results, limit)
    lines = []
    for r in visible:
        rid = r.get("id", r.get("label", "?"))
        project = r.get("project", "")
        fp = r.get("filePath", "")
        start = r.get("startLine", "")
        loc = f" at {fp}:{start}" if fp else ""
        lines.append(f"- `{rid}` [{project}]{loc}")
    if hidden:
        lines.append(f"- *... and {hidden} more (use --limit to see more)*")
    return "\n".join(lines)


def fmt_path(data: dict) -> str:
    path = data.get("path", [])
    hops = data.get("hops", 0)
    if not path:
        return "No call path found."
    lines = [f"Call path ({hops} hop{'s' if hops != 1 else ''}):"]
    for i, node in enumerate(path):
        prefix = "START" if i == 0 else ("END" if i == len(path) - 1 else "→")
        lines.append(f"  {prefix} `{node}`")
    return "\n".join(lines)


def fmt_projects(projects: list, limit: int = 0) -> str:
    if not projects:
        return "No projects indexed yet. Run `pharos index <path>` first."
    visible, hidden = _truncate(projects, limit)
    lines = ["Indexed projects:"]
    for p in visible:
        name = p.get("name", "?")
        methods = p.get("methodCount", 0)
        classes = p.get("classCount", 0)
        last = p.get("lastIndexed", "")
        lines.append(f"- **{name}**: {methods} methods, {classes} classes (last indexed: {last})")
    if hidden:
        lines.append(f"- *... and {hidden} more*")
    return "\n".join(lines)


def fmt_modules(data: dict, limit: int = 0) -> str:
    modules = data.get("modules", [])
    total = data.get("total", 0)
    edges = data.get("edges", 0)
    indexed = sum(1 for m in modules if m.get("indexed"))
    external = total - indexed
    visible, hidden = _truncate(modules, limit)
    lines = [f"Module graph: **{total}** nodes ({indexed} indexed, {external} external), **{edges}** edges\n"]
    for m in visible:
        key = m.get("moduleKey", "?")
        status = f"✓ indexed [{m.get('projectName')}]" if m.get("indexed") else "⊘ external"
        deps = m.get("depCount", 0)
        used = m.get("usedByCount", 0)
        ver = m.get("version", "")
        lines.append(f"- `{key}` {status} — deps: {deps}, used-by: {used}, version: {ver}")
    if hidden:
        lines.append(f"- *... and {hidden} more (use --limit to see more)*")
    return "\n".join(lines)


def fmt_deps(data: dict, limit: int = 0) -> str:
    key = data.get("moduleKey", "?")
    indexed = data.get("indexed", False)
    project = data.get("projectName", "")
    version = data.get("version", "")
    transitive = data.get("transitive", False)
    deps = data.get("dependencies", [])
    dependents = data.get("dependents", [])
    status = f"indexed/{project}" if indexed else "external"
    t_label = "transitive, " if transitive else ""

    lines = [f"**{key}** [{status}] version: {version}\n"]
    vis_deps, hid_deps = _truncate(deps, limit)
    lines.append(f"**Dependencies ({t_label}{len(deps)}):**")
    for d in vis_deps:
        lines.append(f"- → `{d['moduleKey']}` [{'indexed' if d.get('indexed') else 'external'}]")
    if hid_deps:
        lines.append(f"- *... and {hid_deps} more*")
    vis_dep, hid_dep = _truncate(dependents, limit)
    lines.append(f"\n**Used by ({t_label}{len(dependents)}):**")
    for d in vis_dep:
        lines.append(f"- ← `{d['moduleKey']}` [{'indexed' if d.get('indexed') else 'external'}]")
    if hid_dep:
        lines.append(f"- *... and {hid_dep} more*")
    return "\n".join(lines)


def fmt_mod_path(data: dict) -> str:
    path = data.get("path", [])
    hops = data.get("hops", 0)
    if not path:
        return "No dependency path found."
    lines = [f"Dependency path ({hops} hop{'s' if hops != 1 else ''}):"]
    for i, n in enumerate(path):
        marker = "**START**" if i == 0 else ("**END**" if i == len(path) - 1 else "→")
        status = f"indexed/{n.get('projectName')}" if n.get("indexed") else "external"
        lines.append(f"  {marker} `{n['moduleKey']}` [{status}]")
    return "\n".join(lines)


def fmt_skeleton(classes: list, limit: int = 0) -> str:
    """Render skeleton as a filesystem tree grouped by source path."""
    if not classes:
        return "No public/protected classes found."

    # Deduplicate: same qualifiedClassName can appear twice from multi-segment indexes.
    seen_classes: dict[str, dict] = {}
    for cls in classes:
        key = cls.get("qualifiedClassName") or cls.get("className", "?")
        if key not in seen_classes:
            seen_classes[key] = cls
        else:
            # Merge method lists (deduplicate by signature text)
            existing = seen_classes[key]
            existing_sigs = set(existing.get("methods", []))
            for m in cls.get("methods", []):
                if m not in existing_sigs:
                    existing.setdefault("methods", []).append(m)
                    existing_sigs.add(m)
    deduped = list(seen_classes.values())

    visible, hidden = _truncate(deduped, limit)

    # Build tree: map path segments → list of (file_leaf, methods, display_name)
    # We derive a short path from filePath (strip up to src/main/java, src/main/python, etc.)
    # or fall back to the package path from qualifiedClassName.
    def short_path(cls: dict) -> list[str]:
        fp = cls.get("filePath", "")
        if fp:
            fp = fp.replace("\\", "/")
            # Strip everything up to a known source root marker
            for marker in ("/src/main/java/", "/src/main/python/", "/src/main/",
                           "/main/java/", "/main/", "/src/"):
                idx = fp.find(marker)
                if idx >= 0:
                    fp = fp[idx + len(marker):]
                    break
            else:
                # Just use the last N components
                parts = fp.split("/")
                fp = "/".join(parts[-4:]) if len(parts) >= 4 else fp
            return fp.split("/")
        # Fallback: derive from qualified class name
        qname = cls.get("qualifiedClassName", "?")
        parts = qname.replace(".", "/").split("/")
        # Last part is the class — append .java
        parts[-1] = parts[-1].split("$")[0] + ".java"
        return parts

    # Build a nested dict tree: {segment: subtree | None}
    # Leaves: segment is a filename, value is list of method sigs
    tree: dict = {}
    for cls in visible:
        parts = short_path(cls)
        node = tree
        for part in parts[:-1]:
            node = node.setdefault(part, {})
        leaf = parts[-1]
        # Store methods under a special key; merge if leaf already seen
        existing = node.get(leaf)
        methods = cls.get("methods", [])
        if existing is None:
            node[leaf] = {"__methods__": list(methods)}
        elif isinstance(existing, dict):
            seen_m = set(existing.get("__methods__", []))
            for m in methods:
                if m not in seen_m:
                    existing["__methods__"].append(m)
                    seen_m.add(m)

    def render_tree(node: dict, prefix: str = "") -> list[str]:
        out = []
        keys = sorted(node.keys())
        for i, key in enumerate(keys):
            is_last = (i == len(keys) - 1)
            connector = "└── " if is_last else "├── "
            child_prefix = prefix + ("    " if is_last else "│   ")
            val = node[key]
            if isinstance(val, dict):
                methods = val.pop("__methods__", [])
                if val:
                    # Directory with children
                    out.append(f"{prefix}{connector}{key}/")
                    out.extend(render_tree(val, child_prefix))
                else:
                    # File leaf
                    out.append(f"{prefix}{connector}{key}")
                    for j, m in enumerate(methods):
                        # Strip annotation prefixes for readability
                        sig = m.strip()
                        for ann in ("@Override ", "@Override\n"):
                            sig = sig.replace(ann, "")
                        # Collapse long generics
                        m_last = "└── " if j == len(methods) - 1 else "├── "
                        out.append(f"{child_prefix}{m_last}{sig}")
        return out

    lines = render_tree(tree)
    if hidden:
        lines.append(f"\n... and {hidden} more classes (use --limit N to see more)")
    return "\n".join(lines)


def fmt_boundary(data: dict, limit: int = 0) -> str:
    project = data.get("project", "?")
    entry = data.get("entryPoints", [])
    exits = data.get("exitPoints", [])
    total_exits = data.get("totalExitPoints", len(exits))
    lines = [f"**Module boundary for `{project}`**\n"]
    vis_entry, hid_entry = _truncate(entry, limit)
    lines.append(f"**Entry points** (methods called by other linked modules): {len(entry)}")
    if not entry:
        lines.append("- *(none — no linked projects have been indexed yet)*")
    else:
        for fqn in vis_entry:
            lines.append(f"- `{fqn}`")
        if hid_entry:
            lines.append(f"- *... and {hid_entry} more*")
    shown = len(exits)
    exit_label = f"{total_exits}" if total_exits == shown else f"{shown} of {total_exits}"
    lines.append(f"\n**Exit points** (unresolved external calls): {exit_label}")
    if not exits:
        lines.append("- *(none recorded)*")
    else:
        vis_exits, hid_exits = _truncate(exits, limit)
        for ep in vis_exits:
            lines.append(f"- `{ep['callerFqn']}` → `{ep['calleeSimpleName']}` (line {ep['line']})")
        if hid_exits:
            lines.append(f"- *... and {hid_exits} more (use --limit to see more)*")
    return "\n".join(lines)


# ── Command implementations ───────────────────────────────────────────────────

def cmd_search(args):
    ensure_daemon()
    params = {
        "q": args.query,
        "type": args.type,
        "limit": args.limit,
    }
    if args.project:
        params["project"] = args.project
    if args.doc_type != "all":
        params["docType"] = args.doc_type
    if args.expand:
        params["expand"] = "true"
    results = _api_get("/api/search", params)
    print(fmt_search(results))


def cmd_method(args):
    ensure_daemon()
    data = _api_get("/api/method", {"fqn": args.fqn})
    print(fmt_method(data))


def cmd_class(args):
    ensure_daemon()
    data = _api_get("/api/class", {"fqn": args.fqn})
    print(fmt_class(data))


def cmd_callers(args):
    ensure_daemon()
    results = _api_get("/api/callers", {"fqn": args.fqn})
    print(fmt_refs(results, "callers", args.limit))


def cmd_callees(args):
    ensure_daemon()
    results = _api_get("/api/callees", {"fqn": args.fqn})
    print(fmt_refs(results, "callees", args.limit))


def cmd_path(args):
    ensure_daemon()
    data = _api_get("/api/path", {"from": args.from_fqn, "to": args.to_fqn})
    print(fmt_path(data))


def cmd_projects(args):
    ensure_daemon()
    projects = _api_get("/api/projects")
    print(fmt_projects(projects, args.limit))


def cmd_modules(args):
    ensure_daemon()
    data = _api_get("/api/modules", {"filter": args.filter})
    print(fmt_modules(data, args.limit))


def cmd_deps(args):
    ensure_daemon()
    data = _api_get("/api/deps", {"module": args.module, "transitive": str(args.transitive).lower()})
    print(fmt_deps(data, args.limit))


def cmd_mod_path(args):
    ensure_daemon()
    data = _api_get("/api/mod-path", {"from": args.from_module, "to": args.to_module})
    print(fmt_mod_path(data))


def cmd_boundary(args):
    ensure_daemon()
    params = {"project": args.project}
    if args.limit:
        params["limit"] = args.limit
    data = _api_get("/api/boundary", params)
    print(fmt_boundary(data, args.limit))


def cmd_skeleton(args):
    ensure_daemon()
    params = {"project": args.project}
    if args.method_limit:
        params["limit"] = args.method_limit
    if getattr(args, "path", None):
        params["path"] = args.path
    if getattr(args, "depth", None) is not None and args.depth >= 0:
        params["depth"] = args.depth
    classes = _api_get("/api/skeleton", params)
    print(fmt_skeleton(classes, args.limit))


def cmd_index(args):
    """Run indexing by spawning the JAR directly (daemon is search-only, no write lock)."""
    if not JAR.exists():
        die(f"pharos JAR not found at {JAR}\nRun: mvn clean package -DskipTests")

    jvm_flags = ["--enable-native-access=ALL-UNNAMED",
                 "--add-opens", "java.base/java.nio.channels.spi=ALL-UNNAMED"]
    if args.vector_incubator:
        jvm_flags.append("--add-modules jdk.incubator.vector")
    cmd = ["java"] + jvm_flags + ["-jar", str(JAR), "index", str(args.path)]
    if args.project:
        cmd += ["--project", args.project]
    if args.full:
        cmd.append("--full")
    if args.force:
        cmd.append("--force")
    if args.no_embed:
        cmd.append("--no-embed")
    if args.single:
        cmd.append("--single")
    if args.depth != 3:
        cmd += ["--depth", str(args.depth)]
    if args.project_threads != 1:
        cmd += ["--project-threads", str(args.project_threads)]

    result = subprocess.run(cmd)
    sys.exit(result.returncode)


def cmd_web(args):
    """Ensure the daemon is running and open the web UI in a browser."""
    ensure_daemon()
    url = f"http://localhost:{DAEMON_PORT}"
    print(f"Web UI available at {url}")
    if not args.no_open:
        try:
            import webbrowser
            webbrowser.open(url)
        except Exception:
            pass


def cmd_daemon(args):
    """Manage the background daemon."""
    action = args.action
    if action == "status":
        if _is_daemon_running():
            pid = DAEMON_PID_FILE.read_text().strip() if DAEMON_PID_FILE.exists() else "?"
            print(f"pharos daemon is running (pid={pid}, port={DAEMON_PORT})")
        else:
            print("pharos daemon is not running.")
    elif action == "start":
        if _is_daemon_running():
            print(f"pharos daemon is already running on port {DAEMON_PORT}.")
        else:
            print("Starting pharos daemon...", flush=True)
            _start_daemon()
            print(f"pharos daemon started on port {DAEMON_PORT}.")
    elif action == "stop":
        if DAEMON_PID_FILE.exists():
            try:
                pid = int(DAEMON_PID_FILE.read_text().strip())
                os.kill(pid, signal.SIGTERM)
                DAEMON_PID_FILE.unlink(missing_ok=True)
                print(f"pharos daemon (pid={pid}) stopped.")
            except (ProcessLookupError, ValueError):
                DAEMON_PID_FILE.unlink(missing_ok=True)
                print("pharos daemon was not running.")
        else:
            print("pharos daemon is not running.")
    elif action == "restart":
        if DAEMON_PID_FILE.exists():
            try:
                pid = int(DAEMON_PID_FILE.read_text().strip())
                os.kill(pid, signal.SIGTERM)
                time.sleep(1)
            except (ProcessLookupError, ValueError):
                pass
            DAEMON_PID_FILE.unlink(missing_ok=True)
        print("Starting pharos daemon...", flush=True)
        _start_daemon()
        print(f"pharos daemon started on port {DAEMON_PORT}.")
    elif action == "logs":
        if DAEMON_LOG_FILE.exists():
            lines = DAEMON_LOG_FILE.read_text().splitlines()
            print("\n".join(lines[-50:]))
        else:
            print("No daemon log found.")


